{"_id":"855d42e230f83315","name":"DATS Uniform","type":"gear","img":"icons/svg/item-bag.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"itemType":"clothing","target":"tamer","timing":"passive","cost":{"digidollars":0,"realMoney":50,"special":""},"quantity":1,"effect":"+1 to all Ironclad skill rolls while equipped. The uniform is durable enough for Digital World field conditions. Wearing it in human-world contexts gives +2 to official interactions with DATS-affiliated personnel. Wearing it in the Digital World gives NPCs a reason to either respect you or target you, depending on what they think of DATS.","isEquipped":false,"bonuses":{"courage":0,"friendship":0,"love":0,"knowledge":0,"sincerity":0,"reliability":0,"hope":0,"hpDamageReduction":0,"attackBonus":0,"damageBonus":0,"skillBonuses":{"blitz":0,"ironclad":1,"crusher":0,"ghost":0,"roar":0,"scan":0,"rally":0,"broadcast":0,"mend":0,"radar":0,"tame":0,"decode":0,"jackIn":0,"modify":0,"trace":0,"archive":0,"command":0,"playback":0,"firewall":0,"reinforce":0,"coreDrive":0,"zeroError":0,"fieldOps":0,"recovery":0}},"notes":"+1 Ironclad. +2 to official DATS interactions in human world (conditional)."}}
{"_id":"8d9a4e6e63b6a9f4","name":"Data Backup Chip","type":"gear","img":"icons/svg/item-bag.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"itemType":"supply","target":"digimon","timing":"basic-action","cost":{"digidollars":150,"realMoney":0,"special":""},"quantity":1,"effect":"Once as a Basic Action, apply this chip to your partner Digimon. Until the end of the current encounter if your partner Digimon would have their Default Stage reduced, the reduction is delayed by one round — the cascade triggers at the start of their next turn instead of immediately. The chip crumbles after use.","isEquipped":false,"bonuses":{"courage":0,"friendship":0,"love":0,"knowledge":0,"sincerity":0,"reliability":0,"hope":0,"hpDamageReduction":0,"attackBonus":0,"damageBonus":0,"skillBonuses":{"blitz":0,"ironclad":0,"crusher":0,"ghost":0,"roar":0,"scan":0,"rally":0,"broadcast":0,"mend":0,"radar":0,"tame":0,"decode":0,"jackIn":0,"modify":0,"trace":0,"archive":0,"command":0,"playback":0,"firewall":0,"reinforce":0,"coreDrive":0,"zeroError":0,"fieldOps":0,"recovery":0}},"notes":"Delays Default Stage reduction by 1 round. Single use. Partner Digimon only."}}
{"_id":"91813d098e061b36","name":"Digimon World Cloak","type":"gear","img":"icons/svg/item-bag.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"itemType":"clothing","target":"tamer","timing":"passive","cost":{"digidollars":0,"realMoney":0,"special":"Loot only — cannot be purchased"},"quantity":1,"effect":"While equipped in the Digital World, you do not trigger the hostile response from wild Digimon that humans normally cause — neutral Digimon treat you as a Digital World native unless directly provoked. Has no effect in the human world.","isEquipped":false,"bonuses":{"courage":0,"friendship":0,"love":0,"knowledge":0,"sincerity":0,"reliability":0,"hope":0,"hpDamageReduction":0,"attackBonus":0,"damageBonus":0,"skillBonuses":{"blitz":0,"ironclad":0,"crusher":0,"ghost":0,"roar":0,"scan":0,"rally":0,"broadcast":0,"mend":0,"radar":0,"tame":0,"decode":0,"jackIn":0,"modify":0,"trace":0,"archive":0,"command":0,"playback":0,"firewall":0,"reinforce":0,"coreDrive":0,"zeroError":0,"fieldOps":0,"recovery":0}},"notes":"Digital World only. Suppresses human hostile-response trigger with neutral Digimon."}}
