{"_id":"0da4fbbbf10d6070","name":"Data Scan","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Izzy.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Izzy","row":1,"expCost":300,"requirements":"Entry requirement met (Knowledge rank 3+)","description":"Once per encounter as a Basic Action, choose one enemy. You learn their Attribute, Element, and one combat stat of your choice."}}
{"_id":"12577bb276cc98d3","name":"Tactical Override","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Izzy.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Izzy","row":1,"expCost":300,"requirements":"Entry requirement met (Knowledge rank 3+)","description":"Once per encounter as a Free Action on your turn, you may move one allied Digimon up to 2 spaces in any direction before their turn begins."}}
{"_id":"a3cfc94ba1dbdc3a","name":"Calculated Strike","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Izzy.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Izzy","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Knowledge rank 4","description":"Once per encounter when your Digimon misses an attack, you may spend 3 Hope to reroll the attack roll and take the higher result."}}
{"_id":"c535dd8a30146049","name":"Exploit Weakness","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Izzy.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Izzy","row":2,"expCost":500,"requirements":"Data Scan, Knowledge rank 4","description":"When your Digimon attacks an enemy you have already scanned this encounter, they deal +Knowledge rank bonus damage on that attack."}}
{"_id":"e2c2718a4be850f4","name":"Digimon Encyclopedia","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Izzy.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Izzy","row":3,"expCost":700,"requirements":"At least 1 Row 2 ability, Knowledge rank 5","description":"Once per session you may declare that your character has researched a specific Digimon type before this encounter. You automatically know their Attribute, Element, and two combat stats without spending a scan action."}}
{"_id":"a8a31ea36df6390e","name":"Full Analysis","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Izzy.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Izzy","row":3,"expCost":700,"requirements":"Data Scan and Exploit Weakness, Knowledge rank 5","description":"Data Scan now reveals ALL of the target's combat stats in addition to their Attribute and Element."}}
{"_id":"fa88cf4c6cfdcd89","name":"Prodigious","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Izzy.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Izzy","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Knowledge rank 7","description":"Once per encounter after an enemy takes an action, you may use your Free Action to predict their next move. The GM tells you one of the following: which target they will attack next, which move they plan to use, or whether they intend to move. You can only predict one thing per activation."}}
{"_id":"8c08107c1f6310c1","name":"Always Prepared","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Joe.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Joe","row":1,"expCost":300,"requirements":"Entry requirement met (Reliability rank 3+)","description":"At the start of each session you may declare one Supply your character happened to pack. The GM must approve it — no rare Digital World items or major combat advantages. Simple supplies only: bandages, rope, a map, a Digi-Ration. Must be used this session; cannot be carried forward."}}
{"_id":"66ffb2937449a091","name":"Field Dressing","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Joe.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Joe","row":1,"expCost":300,"requirements":"Entry requirement met (Reliability rank 3+)","description":"Once per encounter as your Basic Action, make a Recovery check DN 10. On a success restore HP to any one target equal to your Recovery roll result. This can be used on Digimon."}}
{"_id":"cd4d52eda5b01315","name":"Calculated Risk","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Joe.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Joe","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Reliability rank 4","description":"Once per encounter before any roll is made, you may declare Calculated Risk. Spend 2 Hope and take -2 to the roll — if you succeed the effect is doubled (double healing, double status duration, double damage)."}}
{"_id":"4066e5283260a445","name":"Triage","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Joe.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Joe","row":2,"expCost":500,"requirements":"Field Dressing, Reliability rank 4","description":"Field Dressing can now target two characters in the same action. Split the healing however you choose between the two targets."}}
{"_id":"f286d3f3fafefbb1","name":"Emergency Protocol","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Joe.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Joe","row":3,"expCost":700,"requirements":"Triage, Reliability rank 5","description":"Once per session when any allied Digimon triggers the cascade, you may immediately make a Recovery check DN 14 as a Free Action off-turn. On a success that Digimon stabilizes one stage higher than the cascade result."}}
{"_id":"4cae841d88812465","name":"Steady the Line","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Joe.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Joe","row":3,"expCost":700,"requirements":"At least 1 Row 2 ability, Reliability rank 5","description":"At the start of each encounter before turns begin, you may spend your Free Action to grant all allied Digimon temporary HP equal to your Reliability rank."}}
{"_id":"c5848d85419f2602","name":"The Backup Plan","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Joe.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Joe","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Reliability rank 7","description":"Once per session when the encounter looks lost — all allied Digimon at Default Stage or below, or two or more in egg state — you may activate The Backup Plan as a Free Action. All egg-state Digimon return at In-Training with 1 HP. All Digimon at In-Training or Rookie gain 10 temporary HP."}}
{"_id":"1aa9a9fc45628cd0","name":"Break Through","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Kari.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Kari S1","row":1,"expCost":300,"requirements":"Love rank 3","description":"Once per encounter when your Digimon makes an attack that would have an unfavorable element multiplier (x0.5), you may declare Break Through before damage is calculated. Strip the element multiplier entirely — only attribute matchup applies to this attack."}}
{"_id":"2cba2b7d13263e3e","name":"Cheer","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Kari.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Kari S1","row":1,"expCost":300,"requirements":"Friendship rank 3","description":"When an ally makes a skill check and fails, you may spend Hope equal to your Friendship rank to boost their result by your Friendship rank. Declared after the roll but before the GM rules on the outcome."}}
{"_id":"ab7367f01fe8570c","name":"Gatomon's Legacy","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Kari.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Kari S1","row":2,"expCost":500,"requirements":"Any 1 Row 1 ability, Champion digivolution unlocked","description":"Your Digimon's Max Default Stage increases by 1 permanently. Their Default Stage can now reach one stage higher than the campaign maximum allows for other Digimon. Cannot push beyond Mega."}}
{"_id":"8787cc1116943a95","name":"Loud and Clear","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Kari.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Kari S1","row":2,"expCost":500,"requirements":"Cheer, Friendship rank 4","description":"Once per encounter Cheer is free — costs no Hope. After that first free use it still costs Hope equal to your Friendship rank as normal."}}
{"_id":"621a37ed5ce512a3","name":"Push Further","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Kari.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Kari S1","row":2,"expCost":500,"requirements":"Break Through, Love rank 4","description":"Break Through can now be used additional times per encounter by spending 4 Hope per use after the first. The first use each encounter is still free."}}
{"_id":"96843125aafcff11","name":"Light the Way","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Kari.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Kari S1","row":3,"expCost":700,"requirements":"Push Further, Love rank 5","description":"Break Through can now be used on any allied Digimon's attack, not just your own. When an ally is hitting into an elemental resistance, you may declare Break Through on their behalf. Hope cost still applies and comes from your pool."}}
{"_id":"47f0c302369c3bda","name":"Rally the Team","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Kari.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Kari S1","row":3,"expCost":700,"requirements":"Loud and Clear, Friendship rank 5","description":"When you spend Hope to boost an ally's skill check with Cheer and the roll still fails, the Hope cost is fully refunded. You only pay when the boost actually works."}}
{"_id":"410d483b983c8729","name":"Pack Bond","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Matt.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Matt","row":1,"expCost":300,"requirements":"Entry requirement met (Friendship rank 3+)","description":"Once per encounter you may use your Free Action to grant an ally Digimon within 3 spaces +3 to their next damage roll. You protect what matters to you, even if you won't say it out loud."}}
{"_id":"d255633de8610b45","name":"Solo Run","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Matt.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Matt","row":1,"expCost":300,"requirements":"Entry requirement met (Friendship rank 3+)","description":"Once per encounter when your Digimon is the only Digimon currently active on your side, they gain +2 to all attack rolls and +2 damage. You don't need a team to be dangerous."}}
{"_id":"ed315dabe9894c01","name":"Cold Front","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Matt.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Matt","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Friendship rank 4","description":"Once per encounter when your Digimon is attacked, you may use your Free Action to grant them +4 to their Reliability for that attack only. The wall goes up before the hit lands."}}
{"_id":"8033dc28c53ea1ce","name":"Rival's Fire","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Matt.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Matt","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Friendship rank 4","description":"When an ally Digimon is reduced to 0 HP in the same encounter, your Digimon gains +4 to their next attack roll and +4 damage on that attack. Loss makes them dangerous."}}
{"_id":"7cc3962fe70c16f1","name":"I Work Alone","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Matt.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Matt","row":3,"expCost":700,"requirements":"Solo Run, Friendship rank 5","description":"Solo Run now activates whenever your Digimon acts before any allied Digimon has taken a turn this round, even if other Digimon are present. First in is always alone."}}
{"_id":"c8a2fd06d47390b0","name":"Stand Together","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Matt.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Matt","row":3,"expCost":700,"requirements":"Pack Bond, Friendship rank 5","description":"Pack Bond can now target any ally Digimon anywhere on the battlefield, not just within 3 spaces. When you decide to protect someone, distance does not matter."}}
{"_id":"d73d91e098a0e583","name":"Warp Digivolution","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Matt.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Matt","row":3,"expCost":700,"requirements":"At least 1 Row 2 ability, Friendship rank 5","description":"Your Digimon can now digivolve two stages at once in a single Basic Action, skipping the stage in between. Pay the combined Hope cost of both stages minus 2 to initiate. Warp Digivolution cannot be forced — full cost must always be paid. See Season 1 Rules for full details."}}
{"_id":"2b2f3674550d82af","name":"The Wall","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Matt.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Matt","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Friendship rank 7","description":"Once per session when an attack would reduce an ally Digimon to 0 HP, you may declare The Wall before the damage is applied. The damage is divided evenly between the ally Digimon and your Digimon — both take half, rounded down. The ally always survives at minimum 1 HP. Your Digimon takes their half normally."}}
{"_id":"5fbf0149a44e3f29","name":"Bright Personality","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Mim.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Mimi","row":1,"expCost":300,"requirements":"Entry requirement met (Sincerity rank 3+) — Friendship path","description":"Once per encounter as a Free Action, choose one enemy NPC or Digimon. Make a Broadcast check DN 12. On a success they take -2 to their next attack roll. You have that effect on people."}}
{"_id":"e31a5962358f56c1","name":"Harder Than I Look","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Mim.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Mimi","row":1,"expCost":300,"requirements":"Entry requirement met (Sincerity rank 3+) — Sincerity path","description":"Whenever your Digimon takes damage that would reduce them to below half their max HP, they gain +2 to all damage rolls until the end of the round."}}
{"_id":"7ae95014aefc00e0","name":"Pure Heart","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Mim.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Mimi","row":1,"expCost":300,"requirements":"Entry requirement met (Sincerity rank 3+) — Love path","description":"Once per encounter as a Free Action you may attempt to calm one non-boss enemy Digimon. Make a Tame check DN 14. On a success that Digimon skips their next action."}}
{"_id":"c2e0b89f37005273","name":"Center of Attention","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Mim.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Mimi","row":2,"expCost":500,"requirements":"Bright Personality, Friendship rank 4","description":"Bright Personality now affects all enemies within 3 spaces of the target, not just one."}}
{"_id":"73d5064e41875ea0","name":"I Believe In You","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Mim.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Mimi","row":2,"expCost":500,"requirements":"Pure Heart, Love rank 4","description":"Once per session as your Basic Action, choose one allied Digimon. They immediately restore HP equal to your Sincerity rank x 3 and remove all status effects."}}
{"_id":"33e56bd8738a425b","name":"Won't Stay Down","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Mim.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Mimi","row":2,"expCost":500,"requirements":"Harder Than I Look, Sincerity rank 4","description":"Once per encounter when your Digimon would trigger the cascade at Default Stage, you may spend 8 Hope to have them stay at 1 HP with their Default Stage intact."}}
{"_id":"9179e408c44f8d76","name":"The Mimi Effect","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Mim.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Mimi","row":3,"expCost":800,"requirements":"Any two Row 2 abilities, Sincerity rank 6","description":"Once per session at the start of your turn you may spend 5 Hope to activate The Mimi Effect. Until the start of your next turn all allied Digimon deal +3 damage and all enemy Digimon take -2 to attack rolls."}}
{"_id":"52aaca7e7e09a28b","name":"Read the Room","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Sora.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Sora","row":1,"expCost":300,"requirements":"Entry requirement met (Love rank 3+)","description":"At the start of each encounter you may make a free Radar check (DN 10). On a success the GM tells you one piece of information about the battlefield — a hidden enemy, a terrain hazard, or a weak point."}}
{"_id":"f217a24ed1365909","name":"Steady Hands","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Sora.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Sora","row":1,"expCost":300,"requirements":"Entry requirement met (Love rank 3+)","description":"When you make a Recovery or Mend check, add your Love rank as a bonus to the roll on top of the normal skill formula. Care given with precision goes further."}}
{"_id":"5f0a36f3f59c7790","name":"Protective Instinct","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Sora.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Sora","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Love rank 4","description":"When an ally within 2 spaces is targeted by an attack, you may use your Free Action to move up to 2 spaces toward them as an off-turn free action. This triggers before the hit resolves."}}
{"_id":"4464c5f51442524c","name":"Rally Cry","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Sora.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Sora","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Love rank 4","description":"As a Basic Action, choose one ally Digimon. They immediately remove one stack of any status effect currently affecting them. Can be used as many times per encounter as you have Basic Actions to spend."}}
{"_id":"24052d581d4d0632","name":"Field Medic","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Sora.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Sora","row":3,"expCost":700,"requirements":"Steady Hands, Love rank 5","description":"When you successfully use Recovery during a short rest, both your Tamer AND your Digimon restore HP equal to double the roll result instead of the normal amount."}}
{"_id":"0ee3a2c4fc0acc1e","name":"Never Too Late","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Sora.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Sora","row":3,"expCost":700,"requirements":"Rally Cry, Love rank 5","description":"Once per session when a Digimon in your party would enter egg state, you may immediately spend 10 Hope to prevent it. That Digimon instead stabilizes at In-Training stage with 1 HP."}}
{"_id":"2526b01db7564ee3","name":"Heart of the Team","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Sora.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Sora","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Love rank 7","description":"Once per session at the start of your turn you may activate Heart of the Team. All allied Tamers and Digimon restore HP equal to your Love rank. This does not cost an action."}}
{"_id":"7c1b6ec07b228e18","name":"Last Light","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tk.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"TK","row":1,"expCost":300,"requirements":"Hope pool 20+ (any crest rank 4+)","description":"Once per encounter when your Hope hits 0 and your Digimon would revert, you may instead keep them at their current stage for 1 additional round at no Hope cost."}}
{"_id":"44f70f692f968785","name":"Reservoir","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tk.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"TK","row":1,"expCost":300,"requirements":"Hope pool 20+ (any crest rank 4+)","description":"Your Hope pool increases by 5 permanently, on top of the normal formula. You carry more than most people think possible."}}
{"_id":"dee8fefca1146a18","name":"Miracle Roll","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tk.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"TK","row":2,"expCost":500,"requirements":"Last Light","description":"Once per session when any die roll results in a natural 1, you may spend 6 Hope to reverse it completely. The roll is instead treated as a natural 20."}}
{"_id":"955cc23534727e05","name":"Share the Light","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tk.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"TK","row":2,"expCost":500,"requirements":"Reservoir","description":"Once per encounter as a Free Action you may transfer up to 5 Hope from your pool to any allied Tamer of your choice."}}
{"_id":"4e1a8eac31f5198d","name":"Against All Odds","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tk.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"TK","row":3,"expCost":700,"requirements":"Miracle Roll, Hope pool 30+","description":"Once per session when your Digimon makes an attack roll with a natural result of 2 through 5, you may spend 3 Hope to treat it as a natural 20 — automatic critical hit with double damage."}}
{"_id":"db5aeb73c75f120f","name":"Beacon","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tk.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"TK","row":3,"expCost":700,"requirements":"Share the Light, Hope pool 30+","description":"Once per session at the start of your turn you may declare Beacon. Until the end of the encounter all allied Tamers pay 1 fewer Hope per turn to maintain digivolution (minimum 0). Cannot stack with another active Beacon."}}
{"_id":"a4a446552c7fb108","name":"Crest of Hope","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tk.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"TK","row":4,"expCost":1200,"requirements":"Both Row 3 abilities, Hope pool 40+","description":"Once per major story milestone when the encounter is lost, you may activate Crest of Hope. Every allied Digimon in egg state returns at their Default Stage at full HP. Every allied Tamer's Hope pool refills completely. The round then continues normally."}}
{"_id":"c19efaca478d8513","name":"Lead From the Front","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tai.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tai","row":1,"expCost":300,"requirements":"Entry requirement met (Courage rank 3+)","description":"Once per encounter you may use Call Out as a Free Action on another character's turn, not just your own. Your voice carries even when it is not your moment."}}
{"_id":"ab3cafa7f96a7dd4","name":"Reckless Push","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tai.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tai","row":1,"expCost":300,"requirements":"Entry requirement met (Courage rank 3+)","description":"When you force a digivolution and the roll succeeds, your Digimon gains +3 to their next attack roll this round. Living dangerously pays off."}}
{"_id":"b94cb76f572218eb","name":"Burning Courage","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tai.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tai","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Courage rank 4","description":"When your Digimon is digivolved above their Default Stage, they deal +2 bonus damage on every attack. The higher the risk, the harder they hit."}}
{"_id":"30d80abd4854d22a","name":"No Retreat","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tai.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tai","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Courage rank 4","description":"When your Digimon hits 0 HP above Default Stage, before the cascade triggers you may spend 5 Hope to keep them at 1 HP and maintain their current stage until the end of this round. They are still in the fight."}}
{"_id":"42f31dbad06fef48","name":"Push the Limit","type":"classSkill","img":"systems/digital-destiny/assets/DigiDestined/Tai.webp","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tai","row":3,"expCost":800,"requirements":"Both Row 2 abilities, Courage rank 6","description":"Your Digimon may now digivolve up to 3 stages above Default Stage instead of the normal 2 stage maximum. The Hope costs and corruption rules still apply. Some limits were made to be broken."}}
