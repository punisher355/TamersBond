{"_id":"098b9f54eeaf144c","name":"Tear Apart","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Duskmon","row":2,"expCost":500,"requirements":"Mark the Target, Knowledge rank 4","description":"When your partner Digimon hits a Marked enemy, that enemy loses 1 point of damage resistance until the end of the encounter. This stacks â€” each hit reduces their resistance by 1 more."}}
{"_id":"0d9b7803d2b95c97","name":"The Right Move","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Koji","row":3,"expCost":700,"requirements":"Exposed Weakness, Reliability rank 5","description":"Once per session after your partner Digimon's attack hits, you may deal maximum damage instead of rolling."}}
{"_id":"10bb74803685bddf","name":"Relentless","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Duskmon","row":3,"expCost":700,"requirements":"Tear Apart, Knowledge rank 5","description":"Your partner Digimon's attacks against a Marked enemy cannot be interrupted or redirected â€” abilities that would force your partner to retarget or miss their Marked enemy automatically fail against them."}}
{"_id":"1193473186295379","name":"The Dark Warrior","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Duskmon","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Knowledge rank 7","description":"Once per session at the start of your turn you may declare The Dark Warrior. Mark up to two enemies simultaneously for the rest of this encounter â€” both are Marked at once, costs and effects apply to both. Additionally while The Dark Warrior is active your partner Digimon deals +3 damage on all attacks against Marked enemies. This lasts until the end of the encounter or until both Marked enemies are defeated."}}
{"_id":"12ec212f3e0a1bb9","name":"Stand Your Ground","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Sincerity rank 4","description":"Once per encounter when your partner Digimon is pushed, knocked back, or forcibly moved by an enemy ability, you may negate the movement entirely."}}
{"_id":"1318266fe0825939","name":"For Everyone","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Friendship rank 7","description":"Once per session at the start of an encounter, all allied Digimon and Tamers on the field â€” including yourself â€” gain temporary HP equal to your Friendship rank x3."}}
{"_id":"17b3189caa353f1d","name":"Still Standing","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"LÃ¶wemon","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Sincerity rank 4","description":"Once per encounter at the end of any round in which your partner Digimon took damage, they may immediately move up to 2 spaces as a Free Action."}}
{"_id":"1850ad90147f95f3","name":"Shadow's Guard","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"LÃ¶wemon","row":1,"expCost":300,"requirements":"Entry requirement met (Sincerity rank 3+, Knowledge rank 3+)","description":"Once per encounter when an allied Digimon adjacent to your partner Digimon is targeted by an attack, your partner Digimon may use their Free Action to step in front of the attack. Your partner takes the hit instead. This triggers before the attack roll â€” the attacker must roll against your partner's stats, not the original target's."}}
{"_id":"1b7025c4bdde5813","name":"Unyielding","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":1,"expCost":300,"requirements":"Entry requirement met (Sincerity rank 3+)","description":"Once per encounter when your partner Digimon takes damage, they may immediately move up to 2 spaces as a Free Action."}}
{"_id":"1e55d981a2d25339","name":"Burning Will","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Courage rank 4","description":"Once per encounter when your partner Digimon's attack misses, their next attack roll this turn gains +3."}}
{"_id":"1f49f8fe77b26c2c","name":"Full Commitment","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":3,"expCost":700,"requirements":"Raw Edge, Sincerity rank 5","description":"Once per encounter when your partner Digimon uses a move with the CHARGE tag, they deal +4 damage on that attack."}}
{"_id":"2291d28fda68cb5b","name":"Absolute Honesty","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Sincerity rank 7","description":"Once per session at the start of your turn you may activate Absolute Honesty by spending Hope equal to your Sincerity rank. Until the end of this encounter your partner Digimon cannot miss â€” every attack roll is treated as a hit regardless of the result. A natural 1 deals no damage but the attack still connects, all status effects apply as if it were a hit, and any abilities that trigger on a hit trigger normally."}}
{"_id":"22bb4305ba8c3979","name":"Predator's Patience","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Duskmon","row":1,"expCost":300,"requirements":"Entry requirement met (Knowledge rank 3+)","description":"Once per encounter if your partner Digimon does not attack on their turn, they gain +4 to their next attack roll on their following turn."}}
{"_id":"24c756c04c4cc803","name":"The Other Side","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"LÃ¶wemon","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Sincerity rank 7","description":"Once per session at the start of your turn you may declare The Other Side. For the rest of this encounter your partner Digimon gains the following: when they take damage on behalf of an ally using Shadow's Guard, they take only half that damage. When they defeat an enemy, the nearest allied Digimon restores HP equal to your Sincerity rank. When your Hope hits 0, this ability ends but your partner Digimon stays at their current stage for 1 additional round before reverting."}}
{"_id":"272d7fd9129deefb","name":"Honest Threat","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":1,"expCost":300,"requirements":"Entry requirement met (Sincerity rank 3+)","description":"Once per encounter as a Free Action, choose one enemy Digimon within 4 spaces of your partner. That enemy takes -2 to their next attack roll."}}
{"_id":"2b214799122fec11","name":"Push Through","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":3,"expCost":700,"requirements":"Against the Odds, Courage rank 5","description":"Once per encounter at the start of your turn, if your partner Digimon took damage last round, they may immediately move up to 2 spaces as a Free Action."}}
