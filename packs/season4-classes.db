{"_id":"f41e3244c627bdda","name":"Group Momentum","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Friendship rank 4","description":"Once per encounter at the start of your turn, if at least two allied Digimon acted last round, your partner Digimon gains temporary HP equal to your Friendship rank."}}
