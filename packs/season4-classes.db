{"_id":"961167918ee199f9","name":"Not a Kid Anymore","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Love rank 7","description":"Once per session as a Free Action on your turn, you may spend any amount of your own HP â€” leaving yourself at a minimum of 1 HP â€” to grant that same amount as temporary HP to yourself, your partner Digimon, and all allied Digimon currently on the field."}}
