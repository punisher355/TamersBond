{"_id":"3dee37b366169bae","name":"Mark the Target","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Duskmon","row":1,"expCost":300,"requirements":"Entry requirement met (Knowledge rank 3+)","description":"Once per encounter as a Free Action, designate one enemy Digimon as Marked. While Marked, that enemy takes -2 to all attack rolls. Only one enemy can be Marked at a time. Switching the Mark costs your Free Action."}}
