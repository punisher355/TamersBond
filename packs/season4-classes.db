{"_id":"a7ab654c5bf33a8a","name":"Growing Up","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":3,"expCost":700,"requirements":"I Can Do This, Looked After, Love rank 5","description":"Once per session at the start of an encounter, your partner Digimon's temporary HP from Looked After is doubled."}}
