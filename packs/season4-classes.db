{"_id":"2f9af8adf1e185de","name":"Backup Plan","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":1,"expCost":300,"requirements":"Entry requirement met (Friendship rank 3+)","description":"Once per encounter when an allied Digimon within 3 spaces takes damage, your partner Digimon gains +2 to their next attack roll."}}
{"_id":"4197f6dcaa68b26d","name":"Crowd Presence","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":1,"expCost":300,"requirements":"Entry requirement met (Friendship rank 3+)","description":"Your partner Digimon gains +1 to all attack rolls for each allied Digimon currently on the field, up to a maximum of +3."}}
{"_id":"cc4b7c0579bfb3b4","name":"Take the Hit","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Friendship rank 4","description":"Once per encounter when an allied Digimon within 2 spaces would take damage, your partner Digimon may take that damage instead."}}
{"_id":"f41e3244c627bdda","name":"Group Momentum","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Friendship rank 4","description":"Once per encounter at the start of your turn, if at least two allied Digimon acted last round, your partner Digimon gains temporary HP equal to your Friendship rank."}}
{"_id":"b2c7ef325bfe9357","name":"Thunder Formation","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":3,"expCost":700,"requirements":"Take the Hit, Friendship rank 5","description":"Once per encounter as a Basic Action, choose one allied Digimon within 3 spaces. Until the start of your next turn that Digimon gains +3 to their damage resistance."}}
{"_id":"4e788c17e6079502","name":"Never Alone","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":3,"expCost":700,"requirements":"Group Momentum, Friendship rank 5","description":"Once per session when your partner Digimon would trigger the defeat cascade, you may spend 6 Hope to prevent it if there is at least one other allied Digimon still on the field."}}
{"_id":"1318266fe0825939","name":"For Everyone","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"JP","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Friendship rank 7","description":"Once per session at the start of an encounter, all allied Digimon and Tamers on the field — including yourself — gain temporary HP equal to your Friendship rank x3."}}
{"_id":"7cfe7eb767dfad14","name":"Calculated Strike","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Koji","row":1,"expCost":300,"requirements":"Entry requirement met (Reliability rank 3+)","description":"Once per encounter before your partner Digimon makes an attack roll, you may add your Reliability rank to the roll."}}
{"_id":"e8190da676a72637","name":"Stand Alone","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Koji","row":1,"expCost":300,"requirements":"Entry requirement met (Reliability rank 3+)","description":"When your partner Digimon is the only allied Digimon currently on the field, they gain +2 to all defensive checks."}}
{"_id":"aa7caf06dfc92d86","name":"Precise Form","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Koji","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Reliability rank 4","description":"Once per encounter your partner Digimon may reroll one attack roll and take the higher result."}}
{"_id":"4bef6ad0fb067a80","name":"Cold Read","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Koji","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Reliability rank 4","description":"Once per encounter as a Free Action, name one enemy Digimon. Until the end of this round your partner Digimon's attacks against that target ignore 2 points of damage reduction."}}
{"_id":"a0573a0e05c8c50e","name":"Lone Wolf Stance","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Koji","row":3,"expCost":700,"requirements":"Precise Form, Reliability rank 5","description":"Once per encounter at the start of your turn, you may declare Lone Wolf Stance. Until the start of your next turn your partner Digimon cannot be targeted by status effects."}}
{"_id":"0d9b7803d2b95c97","name":"The Right Move","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Koji","row":3,"expCost":700,"requirements":"Cold Read, Reliability rank 5","description":"Once per session after your partner Digimon's attack hits, you may deal maximum damage instead of rolling."}}
{"_id":"75a2a1833257399e","name":"Twin Souls","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Koji","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Reliability rank 7","description":"Once per session at the start of your turn you may activate Twin Souls. For the rest of this encounter your partner Digimon gains +3 to all attack rolls and all damage rolls. Additionally when they would take damage you may spend 3 Hope to reduce it by your Reliability rank."}}
{"_id":"9906ca5745a08f75","name":"First to Move","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":1,"expCost":300,"requirements":"Entry requirement met (Courage rank 3+)","description":"At the start of each encounter your partner Digimon may immediately move up to 2 spaces before the first turn begins. This movement does not cost an action."}}
{"_id":"fc3635351e6b1131","name":"I Can Take It","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":1,"expCost":300,"requirements":"Entry requirement met (Courage rank 3+)","description":"Once per encounter when your partner Digimon takes damage that would reduce them below half their maximum HP for their current stage, they gain temporary HP equal to your Courage rank."}}
{"_id":"1e55d981a2d25339","name":"Burning Will","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Courage rank 4","description":"Once per encounter when your partner Digimon's attack misses, their next attack roll this turn gains +3."}}
{"_id":"7ecdd18a9e5f729b","name":"Against the Odds","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Courage rank 4","description":"Your partner Digimon deals +2 damage on all attacks while they are below half their maximum HP."}}
{"_id":"592cc8d67c40a224","name":"Blaze of Glory","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":3,"expCost":700,"requirements":"Burning Will, Courage rank 5","description":"Once per session when your partner Digimon would be reduced to 0 HP, you may spend 8 Hope to keep them at 1 HP instead. They do not cascade. They do not dedigivolve."}}
{"_id":"2b214799122fec11","name":"Push Through","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":3,"expCost":700,"requirements":"Against the Odds, Courage rank 5","description":"Once per encounter at the start of your turn, if your partner Digimon took damage last round, they may immediately move up to 2 spaces as a Free Action."}}
{"_id":"be8b6c6ed0c673fd","name":"Unified Flame","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Courage rank 7","description":"Once per session at the start of your turn you may declare Unified Flame. For the rest of this encounter your partner Digimon deals +3 damage on all attacks and cannot be reduced below 1 HP by any single hit — if they are at 1 HP and take any further damage, that damage applies normally. Additionally at the start of each of your turns, if your partner Digimon's HP is below 5, it is immediately restored to 5. This lasts until the end of the encounter or until your Hope hits 0."}}
{"_id":"426a49a9237f6575","name":"Looked After","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":1,"expCost":300,"requirements":"Entry requirement met (Love rank 3+)","description":"At the start of each encounter your partner Digimon gains temporary HP equal to your Love rank."}}
{"_id":"fa2b907e7a0ca710","name":"Quiet Determination","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":1,"expCost":300,"requirements":"Entry requirement met (Love rank 3+)","description":"Once per encounter when your partner Digimon takes damage, they gain +1 to all attack rolls for the rest of this round. It stacks up to +3."}}
{"_id":"6c9bb06de34fe32d","name":"I Can Do This","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Love rank 4","description":"Once per encounter when your partner Digimon's HP drops below half their maximum for their current stage, they gain +2 to all damage rolls for the rest of the encounter."}}
{"_id":"5dd3f5641a4c8530","name":"Protect Them Back","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Love rank 4","description":"Once per encounter when an enemy Digimon adjacent to your partner Digimon initiates a grapple against an allied Digimon, you may force that grapple to target your partner Digimon instead."}}
{"_id":"a7ab654c5bf33a8a","name":"Growing Up","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":3,"expCost":700,"requirements":"I Can Do This, Looked After, Love rank 5","description":"Once per session at the start of an encounter, your partner Digimon's temporary HP from Looked After is doubled."}}
{"_id":"b70992f10316e5d7","name":"Steady Resolve","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":3,"expCost":700,"requirements":"Protect Them Back, Love rank 5","description":"Once per encounter when your partner Digimon is targeted by a grapple, your partner Digimon gains +3 to their grapple resistance check."}}
{"_id":"961167918ee199f9","name":"Not a Kid Anymore","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Love rank 7","description":"Once per session as a Free Action on your turn, you may spend any amount of your own HP — leaving yourself at a minimum of 1 HP — to grant that same amount as temporary HP to yourself, your partner Digimon, and all allied Digimon currently on the field."}}
{"_id":"1b7025c4bdde5813","name":"Unyielding","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":1,"expCost":300,"requirements":"Entry requirement met (Sincerity rank 3+)","description":"Once per encounter when your partner Digimon takes damage, they may immediately move up to 2 spaces as a Free Action."}}
{"_id":"272d7fd9129deefb","name":"Honest Threat","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":1,"expCost":300,"requirements":"Entry requirement met (Sincerity rank 3+)","description":"Once per encounter as a Free Action, choose one enemy Digimon within 4 spaces of your partner. That enemy takes -2 to their next attack roll."}}
{"_id":"12ec212f3e0a1bb9","name":"Stand Your Ground","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Sincerity rank 4","description":"Once per encounter when your partner Digimon is pushed, knocked back, or forcibly moved by an enemy ability, you may negate the movement entirely."}}
{"_id":"71e3613c220758f9","name":"Raw Edge","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Sincerity rank 4","description":"Once per encounter your partner Digimon may make one additional attack as a Free Action at the end of their turn. This attack deals half damage."}}
{"_id":"f158ac1d480da2bb","name":"Speak Plainly","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":3,"expCost":700,"requirements":"Stand Your Ground, Sincerity rank 5","description":"Once per session at the start of an encounter, choose one ally. For this encounter that ally's partner Digimon gains +2 to all attack rolls."}}
{"_id":"1f49f8fe77b26c2c","name":"Full Commitment","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":3,"expCost":700,"requirements":"Raw Edge, Sincerity rank 5","description":"Once per encounter when your partner Digimon uses a move with the CHARGE tag, they deal +4 damage on that attack."}}
{"_id":"2291d28fda68cb5b","name":"Absolute Honesty","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Zoe","row":4,"expCost":1000,"requirements":"Both Row 3 abilities, Sincerity rank 7","description":"Once per session at the start of your turn you may activate Absolute Honesty by spending Hope equal to your Sincerity rank. Until the end of this encounter your partner Digimon cannot miss — every attack roll is treated as a hit regardless of the result. A natural 1 deals no damage but the attack still connects, all status effects apply as if it were a hit, and any abilities that trigger on a hit trigger normally."}}
