{"_id":"544446d4e13acba9","name":"Eyes Everywhere","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Duskmon","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Knowledge rank 4","description":"Once per encounter as a Free Action, you may learn the current HP total of any one visible enemy. Additionally your partner Digimon deals +2 damage to any enemy currently below half their maximum HP."}}
{"_id":"592cc8d67c40a224","name":"Blaze of Glory","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Takuya","row":3,"expCost":700,"requirements":"Burning Will, Courage rank 5","description":"Once per session when your partner Digimon would be reduced to 0 HP, you may spend 8 Hope to keep them at 1 HP instead. They do not cascade. They do not dedigivolve."}}
{"_id":"5dd3f5641a4c8530","name":"Protect Them Back","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Love rank 4","description":"Once per encounter when an enemy Digimon adjacent to your partner Digimon initiates a grapple against an allied Digimon, you may force that grapple to target your partner Digimon instead."}}
{"_id":"6c9bb06de34fe32d","name":"I Can Do This","type":"classSkill","img":"icons/svg/ability.svg","effects":[],"flags":{},"folder":null,"sort":0,"ownership":{"default":0},"system":{"class":"Tommy","row":2,"expCost":500,"requirements":"At least 1 Row 1 ability, Love rank 4","description":"Once per encounter when your partner Digimon's HP drops below half their maximum for their current stage, they gain +2 to all damage rolls for the rest of the encounter."}}
